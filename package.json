{
  "name": "chrome-ext-boilerplate",
  "version": "1.0.0",
  "description": "Mike Lembo's personal Chrome extension boilerplate (React 19, Vite 8 + Rolldown, Tailwind 4, ESLint 10, TypeScript 6, MV3, pnpm + Turbo)",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "author": "Mike Lembo <mike@lembo.email>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emlembow/chrome-ext-boilerplate.git"
  },
  "homepage": "https://github.com/Emlembow/chrome-ext-boilerplate#readme",
  "bugs": "https://github.com/Emlembow/chrome-ext-boilerplate/issues",
  "keywords": [
    "chrome-extension",
    "boilerplate",
    "react",
    "vite",
    "tailwindcss",
    "typescript",
    "manifest-v3",
    "monorepo",
    "pnpm",
    "turbo"
  ],
  "type": "module",
  "scripts": {
    "clean:bundle": "rimraf dist && turbo clean:bundle",
    "clean:node_modules": "pnpx rimraf node_modules && pnpx turbo clean:node_modules",
    "clean:turbo": "rimraf .turbo && turbo clean:turbo",
    "clean": "pnpm clean:bundle && pnpm clean:turbo && pnpm clean:node_modules",
    "clean:install": "pnpm clean:node_modules && pnpm install --frozen-lockfile",
    "type-check": "turbo type-check",
    "base-build": "pnpm clean:bundle && turbo build",
    "build": "pnpm set-global-env && pnpm base-build",
    "build:firefox": "pnpm set-global-env CLI_CEB_FIREFOX=true && pnpm base-build",
    "base-dev": "pnpm clean:bundle && turbo ready && turbo watch dev",
    "dev": "pnpm set-global-env CLI_CEB_DEV=true && pnpm base-dev",
    "dev:firefox": "pnpm set-global-env CLI_CEB_DEV=true CLI_CEB_FIREFOX=true && pnpm base-dev",
    "zip": "pnpm build && pnpm -F zipper zip",
    "zip:firefox": "pnpm build:firefox && pnpm -F zipper zip",
    "ext:lint": "web-ext lint --source-dir dist --no-config-discovery --self-hosted",
    "ext:run": "web-ext run --source-dir dist --no-config-discovery",
    "ext:run:firefox": "web-ext run --source-dir dist --no-config-discovery --target firefox-desktop",
    "e2e": "pnpm zip && turbo e2e",
    "e2e:firefox": "pnpm zip:firefox && turbo e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preflight": "pnpm type-check && pnpm lint && pnpm test && pnpm build",
    "lint": "turbo lint --continue",
    "lint:fix": "turbo lint:fix --continue",
    "format": "turbo format --continue -- --cache --cache-location node_modules/.cache/.prettiercache",
    "prepare": "husky",
    "update-version": "bash bash-scripts/update_version.sh",
    "copy-env": "bash bash-scripts/copy_env.sh",
    "set-global-env": "bash bash-scripts/set_global_env.sh",
    "module-manager": "pnpm -F module-manager start",
    "postinstall": "pnpm copy-env"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.40",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "deepmerge": "^4.3.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "rimraf": "^6.1.3",
    "run-script-os": "^1.1.6",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.1.5",
    "web-ext": "^10.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10"
  }
}
