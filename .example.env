# Copied to .env automatically on `pnpm install` (postinstall: pnpm copy-env).
#
# Naming rules:
#   CEB_*      → exposed to extension code via `process.env` (Vite injects at build).
#   CLI_CEB_*  → only available to build scripts / tooling (NOT injected into bundle).
#
# To add a new var: add `CEB_FOO=` here, run `pnpm install` (or copy manually to .env),
# then reference as `process.env.CEB_FOO` from anywhere in extension code.

# Sample variable shipped in the bundle.
CEB_EXAMPLE=example_env

# i18n locale used during `pnpm dev` (see packages/i18n/locales/). Empty = default (en).
CEB_DEV_LOCALE=

# Set to "true" in CI environments to suppress interactive prompts in scripts.
CEB_CI=
