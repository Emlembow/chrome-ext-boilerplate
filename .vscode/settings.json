{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [{ "pattern": "packages/*" }, { "pattern": "pages/*" }, "chrome-extension", "tests/e2e"],
  "eslint.runtime": "node",
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "tailwindCSS.experimental.configFile": "packages/ui/global.css",
  "tailwindCSS.classFunctions": ["cn", "cva", "clsx", "twMerge"],
  "files.exclude": {
    "**/.turbo": true,
    "**/dist": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/.turbo": true,
    "**/dist": true,
    "**/pnpm-lock.yaml": true,
    "**/node_modules": true
  }
}
